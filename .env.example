# 复制此文件为 .env，填入你的 API Key
# 注册地址: https://platform.deepseek.com

DEEPSEEK_API_KEY=sk-your-api-key-here
# DeepSeek 新版 base_url 不加 /v1（OpenAI SDK 自动补全）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# deepseek-chat 将于 2026/07/24 弃用，届时改为 deepseek-v4-pro
DEEPSEEK_MODEL=deepseek-chat

# 高德地图 API Key（MCP 地理编码，地名→坐标）
# 不设置则仅支持 GPS 坐标输入模式
# 申请地址: https://console.amap.com/dev/key/app
AMAP_API_KEY=

# 无人机模拟参数
DRONE_DEVICE_ID=DJI-Matrice-001
DRONE_BATTERY=85
DRONE_HOME_LAT=31.025
DRONE_HOME_LNG=121.435
